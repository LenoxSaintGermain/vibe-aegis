# GCP Project ID (find at console.cloud.google.com)
# This must match your Firebase project where Firestore is configured
FIREBASE_PROJECT_ID=orbital-prod

# Gemini Vertex AI project (should match FIREBASE_PROJECT_ID)
GEMINI_PROJECT_ID=orbital-prod

# Vertex AI location (us-central1 has Gemini 3 Flash availability)
GEMINI_LOCATION=us-central1

# Environment (development/production)
NODE_ENV=development

# Server port (Cloud Run sets this to 8080 automatically)
PORT=3000
